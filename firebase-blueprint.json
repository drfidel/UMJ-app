{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the UMAJ platform (Author, Reviewer, or Admin).",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["author", "reviewer", "editor", "admin", "subscribed_reader", "unsubscribed_reader", "institutional"] },
        "affiliation": { "type": "string", "description": "Institution or hospital" },
        "specialties": { "type": "array", "items": { "type": "string" }, "description": "Medical specialties for reviewers" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "displayName", "role", "createdAt"]
    },
    "Article": {
      "title": "Article",
      "description": "A published medical journal article.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "abstract": { "type": "string" },
        "authors": { "type": "array", "items": { "type": "string" }, "description": "List of author names" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "pdfUrl": { "type": "string", "format": "uri" },
        "doi": { "type": "string" },
        "volume": { "type": "number" },
        "issue": { "type": "number" },
        "publishedAt": { "type": "string", "format": "date-time" },
        "views": { "type": "number" },
        "downloads": { "type": "number" }
      },
      "required": ["id", "title", "abstract", "authors", "pdfUrl", "volume", "issue", "publishedAt"]
    },
    "Submission": {
      "title": "Submission",
      "description": "A manuscript submitted for review.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorUid": { "type": "string", "description": "UID of the submitting author" },
        "title": { "type": "string" },
        "abstract": { "type": "string" },
        "coAuthors": { "type": "array", "items": { "type": "string" } },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "fileUrl": { "type": "string", "format": "uri" },
        "status": { "type": "string", "enum": ["submitted", "under_review", "accepted", "rejected", "revision_requested"] },
        "submittedAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "authorUid", "title", "abstract", "fileUrl", "status", "submittedAt", "updatedAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A peer review for a submission.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "submissionId": { "type": "string" },
        "reviewerUid": { "type": "string" },
        "comments": { "type": "string" },
        "recommendation": { "type": "string", "enum": ["accept", "minor_revision", "major_revision", "reject"] },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "assignedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "submissionId", "reviewerUid", "status", "assignedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles and roles."
    },
    "articles/{articleId}": {
      "schema": { "$ref": "#/entities/Article" },
      "description": "Published articles available to the public."
    },
    "submissions/{submissionId}": {
      "schema": { "$ref": "#/entities/Submission" },
      "description": "Manuscripts submitted by authors."
    },
    "reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Peer reviews assigned to reviewers."
    }
  }
}
